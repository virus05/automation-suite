import os
from backup.backup_system import backup_system_config

def test_backup_system_create_archive(tmp_path):
    # Create a temporary source directory
    src_dir = tmp_path / "etc"
    src_dir.mkdir()
    (src_dir / "config.txt").write_text("test")

    # Create a temporary destination directory
    dest_dir = tmp_path / "backups"

    # Run the backup function
    backup_path = backup_system_config(str(src_dir), str(dest_dir))

    # Verify that the backup archive was created
    assert backup_path.endswith(".tar.gz")
    assert os.path.exists(backup_path)
